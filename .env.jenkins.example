# Configuración de Variables de Entorno para Jenkins Local
# Copiar este archivo a un lugar seguro y cargar en Jenkins

# Proyecto GCP
GCP_PROJECT=proyectoIngesoft

# Cluster Kubernetes
GKE_CLUSTER_NAME=circle-guard-cluster
GKE_CLUSTER_LOCATION=us-central1

# Docker Registry
DOCKER_IMAGE_PREFIX=diegoapolancol/circleguard
DOCKER_REGISTRY=docker.io

# Servicios a construir (6 microservicios)
SERVICES_TO_BUILD="circleguard-auth-service circleguard-identity-service circleguard-gateway-service circleguard-form-service circleguard-promotion-service circleguard-notification-service"

# Variables de build
BUILD_GRADLE_VERSION=8.14
GRADLE_TASK=:services:*:bootJar

# QR Secret (cambiar a valor real)
QR_SECRET=change-me-change-me-change-me-change-me

# Spring Boot y bases de datos
SPRING_BOOT_VERSION=3.2.4
POSTGRES_VERSION=16.13
REDIS_VERSION=7.0
NEO4J_VERSION=5.0
KAFKA_VERSION=3.0

# Kubernetes namespaces
K8S_NAMESPACES="dev stage prod"

# Timeouts y configuración
K8S_WAIT_TIMEOUT=600
DOCKER_BUILD_TIMEOUT=1800
GRADLE_BUILD_TIMEOUT=1200

# Credenciales (referidas como IDs de Jenkins, no valores directos)
# - dockerhub-credentials: Docker Hub user/token
# - kubeconfig-credentials: Secret file con kubeconfig
# - gcp-sa-json: Secret file con Service Account JSON
# - qr-secret-value: Secret text con QR_SECRET

# Flags opcionales
USE_GKE_PROVIDER=true
ENABLE_TERRAFORM=true
RUN_SMOKE_TESTS=true
PUSH_IMAGES=true
