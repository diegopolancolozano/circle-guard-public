# ---------------------------------------------------------------------------
# infra/terraform root workspace (all environments)
# Copy to terraform.tfvars and fill in real values.
# ---------------------------------------------------------------------------

# GKE mode (recommended for GCP)
use_gke              = true
gcp_project          = "TU_PROJECT_ID"
gke_cluster_name     = "circleguard-stage"
gke_cluster_location = "us-central1"

# Local kubeconfig fallback (set use_gke=false and fill this in for DO/local)
# kubeconfig_path = "./kubeconfig-credentials.yaml"

dockerhub_username = "TU_USUARIO_DOCKERHUB"
dockerhub_password = "TU_TOKEN_DOCKERHUB"
dockerhub_email    = "tu-correo@ejemplo.com"

# Generate with: openssl rand -hex 32
qr_secret = "CAMBIA_ESTE_SECRET_32_CHARS_MIN"

# environments = ["dev", "stage", "prod"]
