# =============================================================================
# CircleGuard — Credenciales Multi-Cloud
#
#   cp .env.example .env
#   # rellena los valores
#   # todos los scripts de scripts/ci/ cargan este archivo automáticamente
#
# NUNCA subas .env a git — está en .gitignore
# =============================================================================

# ── Docker Hub ────────────────────────────────────────────────────────────────
# Crea un token en: https://hub.docker.com/settings/security
DOCKERHUB_USERNAME=tu_usuario_dockerhub
DOCKERHUB_PASSWORD=tu_token_dockerhub
DOCKERHUB_EMAIL=tu@email.com

# ── Secrets compartidos ───────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
QR_SECRET=cambia_esto_genera_con_openssl_rand_hex_32

# ── SSH key (compartida entre GCP y DO) ───────────────────────────────────────
# Genera con: ssh-keygen -t ed25519 -f ~/.ssh/circleguard -C "circleguard"
# Deja vacío para que los scripts la generen automáticamente.
SSH_PUBLIC_KEY=

# =============================================================================
# GOOGLE CLOUD PLATFORM (GCP)
# =============================================================================

# Ruta local al JSON del Service Account de GCP.
# Crea uno en: IAM → Service Accounts → Keys → Add Key → JSON
GCP_SA_FILE=~/.config/gcloud/circleguard-sa.json

# ID del proyecto GCP
GCP_PROJECT=tu-gcp-project-id

# Región y zona
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Cluster GKE
GKE_CLUSTER_NAME=circleguard-stage
GKE_CLUSTER_LOCATION=us-central1

# Usuario SSH para las VMs de GCP (se crea en el Droplet/VM)
GCP_SSH_USER=deployer

# --- Terraform GCP (TF_VAR_ se mapean automáticamente a variables.tf) --------
# Estos son los valores que antes estaban en terraform.tfvars (que es gitignored).
# Con el .env NO necesitas editar ningún terraform.tfvars manualmente.
TF_VAR_project_id=tu-gcp-project-id   # igual que GCP_PROJECT
TF_VAR_ssh_user=deployer              # igual que GCP_SSH_USER

# =============================================================================
# DIGITALOCEAN
# =============================================================================

# Token API de DO: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DO Spaces (backend de estado de Terraform)
# Genera en: https://cloud.digitalocean.com/spaces → Manage Keys
SPACES_ACCESS_KEY_ID=tu_spaces_key
SPACES_SECRET_ACCESS_KEY=tu_spaces_secret

# Nombre del cluster DOKS (debe coincidir con var.cluster_name en terraform)
DOKS_CLUSTER_NAME=circleguard-stage

# --- Terraform DO -------------------------------------------------------------
TF_VAR_k8s_version=1.32.2-do.0

# =============================================================================
# SONARQUBE (opcional — el pipeline lo omite si están vacíos)
# =============================================================================
# SONAR_HOST_URL=http://localhost:9000
# SONAR_TOKEN=squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
